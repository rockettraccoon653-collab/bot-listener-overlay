# Twitch chat listener credentials (bot account)
TWITCH_BOT_USERNAME=
TWITCH_BOT_OAUTH_TOKEN=oauth:
TWITCH_CHANNEL=

# Twitch Extension broadcast credentials
# TWITCH_BROADCASTER_ID must be the numeric channel ID where the extension is installed.
# TWITCH_EXTENSION_OWNER_USER_ID should be the extension owner's Twitch user ID.
TWITCH_EXTENSION_CLIENT_ID=
TWITCH_EXTENSION_OWNER_USER_ID=
TWITCH_EXTENSION_SECRET_BASE64=
TWITCH_BROADCASTER_ID=

# Optional message behavior
MIN_RELAY_LENGTH=4
MAX_RELAY_PER_10S=18
STATE_BROADCAST_INTERVAL_MS=15000

# Boss lifecycle timing
# BOSS_COOLDOWN_MS controls the wait after defeat/clear/retreat before the next automatic spawn.
# BOSS_INITIAL_SPAWN_MS can override only the startup wait; it defaults to BOSS_COOLDOWN_MS.
BOSS_COOLDOWN_MS=600000
BOSS_INITIAL_SPAWN_MS=600000
BOSS_RETREAT_MS=300000

# Local OBS/test relay (recommended when not running inside Twitch Extension context)
LOCAL_WS_ENABLED=true
LOCAL_WS_PORT=8787
LOCAL_WS_DEBUG=true

# Local guild site for profile/shop browsing
LOCAL_SITE_ENABLED=true
LOCAL_SITE_HOST=127.0.0.1
LOCAL_SITE_PORT=8788

# Admin chat command permissions
ALLOW_ADMIN_MODS=true

# Scene relay provider: streamlabs, obs, off
SCENE_RELAY_PROVIDER=streamlabs

# Streamlabs Desktop Third Party Connections (SockJS JSON-RPC)
STREAMLABS_SCENE_RELAY_ENABLED=true
STREAMLABS_API_URL=http://127.0.0.1:59650/api
STREAMLABS_API_TOKEN=
STREAMLABS_SCENE_POLL_MS=1250
STREAMLABS_RECONNECT_MS=5000

# OBS WebSocket fallback
OBS_SCENE_RELAY_ENABLED=false
OBS_WS_URL=ws://127.0.0.1:4455
OBS_WS_PASSWORD=
OBS_RECONNECT_MS=5000
OBS_CONNECT_TIMEOUT_MS=8000